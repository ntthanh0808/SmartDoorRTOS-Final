{
  "expo": {
    "name": "SmartDoor",
    "slug": "smartdoor",
    "version": "1.0.0",
    "orientation": "portrait",
    "plugins": [
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": [
            "peripheral",
            "central"
          ],
          "bluetoothAlwaysPermission": "Cho phép $(PRODUCT_NAME) kết nối Bluetooth để mở cửa"
        }
      ]
    ],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT"
      ],
      "package": "com.anonymous.smartdoor"
    },
    "extra": {
      "apiUrl": "http://192.168.0.100:8000/api",
      "wsUrl": "ws://192.168.0.100:8000/ws"
    }
  }
}
